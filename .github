name: Atualizar projeções BCB

on:
  workflow_dispatch:
  schedule:
    - cron: "20 11 * * 1"

permissions:
  contents: write

jobs:
  atualizar:
    runs-on: ubuntu-latest
    steps:
      - name: Baixar repositório
        uses: actions/checkout@v4

      - name: Consultar Boletim Focus
        shell: bash
        run: |
          python <<'PY'
          import json
          import re
          import urllib.parse
          import urllib.request
          from datetime import datetime, timezone
          from pathlib import Path

          ENDPOINT = (
              "https://olinda.bcb.gov.br/olinda/servico/Expectativas/"
              "versao/v1/odata/ExpectativasMercadoAnuais"
          )

          def number(value):
              if value is None:
                  return None
              try:
                  return float(str(value).replace(",", "."))
              except (TypeError, ValueError):
                  return None

          def year(value):
              match = re.search(r"(20\d{2})", str(value or ""))
              return int(match.group(1)) if match else None

          def get_indicator(indicator):
              params = {
                  "$top": "10000",
                  "$filter": f"Indicador eq '{indicator}'",
                  "$orderby": "Data desc",
                  "$format": "json",
              }
              url = ENDPOINT + "?" + urllib.parse.urlencode(params)
              request = urllib.request.Request(
                  url,
                  headers={
                      "User-Agent": "FinTrack-GitHub-Actions/1.0",
                      "Accept": "application/json",
                  },
              )
              with urllib.request.urlopen(request, timeout=40) as response:
                  payload = json.load(response)

              rows = payload.get("value") or []
              if not rows:
                  raise RuntimeError(f"Sem dados para {indicator}")

              dates = sorted(str(row.get("Data") or "") for row in rows if row.get("Data"))
              latest_date = dates[-1]
              latest_rows = [row for row in rows if str(row.get("Data") or "") == latest_date]

              values = {}
              for row in latest_rows:
                  ref_year = year(row.get("DataReferencia"))
                  median = number(row.get("Mediana"))
                  if ref_year is None or median is None:
                      continue

                  respondents = number(row.get("numeroRespondentes")) or 0
                  base = number(row.get("baseCalculo"))
                  # Dá preferência à série com maior número de respondentes;
                  # em empate, prefere baseCalculo 0.
                  score = (respondents, 1 if base == 0 else 0)
                  if ref_year not in values or score > values[ref_year][1]:
                      values[ref_year] = (median, score)

              return latest_date, {ref_year: item[0] for ref_year, item in values.items()}

          selic_date, selic = get_indicator("Selic")
          ipca_date, ipca = get_indicator("IPCA")

          common_years = sorted(set(selic) & set(ipca))
          if not common_years:
              raise RuntimeError("Não foi possível combinar as curvas anuais de SELIC e IPCA")

          projections = [
              {
                  "ano": ref_year,
                  "selic": round(selic[ref_year], 4),
                  "ipca": round(ipca[ref_year], 4),
                  "fonte": "Focus/BCB",
              }
              for ref_year in common_years
          ]

          output = {
              "fonte": "Banco Central do Brasil — Boletim Focus",
              "indicador": "ExpectativasMercadoAnuais",
              "atualizadoEm": max(selic_date, ipca_date),
              "coletadoEm": datetime.now(timezone.utc).isoformat(),
              "projecoes": projections,
          }

          path = Path("data/projecoes-bcb.json")
          path.parent.mkdir(parents=True, exist_ok=True)
          path.write_text(
              json.dumps(output, ensure_ascii=False, indent=2) + "\n",
              encoding="utf-8",
          )
          print(json.dumps(output, ensure_ascii=False, indent=2))
          PY

      - name: Publicar atualização
        shell: bash
        run: |
          if git diff --quiet -- data/projecoes-bcb.json; then
            echo "Nenhuma alteração nas projeções."
            exit 0
          fi
          git config user.name "github-actions[bot]"
          git config user.email "41898282+github-actions[bot]@users.noreply.github.com"
          git add data/projecoes-bcb.json
          git commit -m "Atualiza projeções SELIC e IPCA do BCB"
          git push
